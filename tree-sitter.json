{
  "grammars": [
    {
      "name": "advpl",
      "camelcase": "Advpl",
      "scope": "source.advpl",
      "path": ".",
      "file-types": [
        "prw",
        "prx",
        "ppo",
        "tlpp"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Grammar Tree-sitter minimo para AdvPL/TLPP (TOTVS Protheus), usado por la extension de Zed",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-advpl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
